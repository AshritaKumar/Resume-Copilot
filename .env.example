# ── Required ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/confido_hiring
OPENAI_API_KEY=sk-...

# ── Langfuse ──────────────────────────────────────────────────────────────────
LANGFUSE_HOST=https://us.cloud.langfuse.com
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_LABEL=production
REQUIRE_LANGFUSE_PROMPTS=true

# ── Langfuse prompt names (must match names registered in Langfuse) ────────────
CANDIDATE_EXTRACTION_PROMPT_NAME=Candidate_Extraction
JD_PARSE_PROMPT_NAME=JD_Parse
OUTREACH_PROMPT_NAME=outreach
INTERVIEW_PROMPT_NAME=intervoew
RAG_ANSWER_PROMPT_NAME=rag_answer
JUDGE_SYSTEM_PROMPT_NAME=llm_judge

# ── Models ─────────────────────────────────────────────────────────────────────
PRIMARY_LLM_MODEL=gpt-4.1-mini
HIGH_STAKES_LLM_MODEL=gpt-4.1
EMBEDDING_MODEL=text-embedding-3-small

# ── RAG chat / retrieval tuning ───────────────────────────────────────────────
# RETRIEVAL_TOP_K=10
# CHUNK_SIZE=900
# CHUNK_OVERLAP=120
# RAG_MAX_DISTANCE=0.62
# RAG_NEAR_BEST_MARGIN=0.18
# RAG_EVIDENCE_CHAR_LIMIT=900
# RAG_CONTEXT_MAX_CHUNKS=12
# RAG_RETRIEVAL_POOL_MULTIPLIER=2.5
# RAG_LEXICAL_WEIGHT=0.32
# RAG_ENABLE_QUERY_REWRITE=true
# RAG_ENABLE_ANSWER_JUDGE=true
